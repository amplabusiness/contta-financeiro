# ==========================================
# Variáveis de Ambiente - Contta Financeiro
# ==========================================
# Configure como CODESPACE SECRETS no GitHub:
#   Settings → Codespaces → Secrets → New secret
#
# Ou copie para .env e preencha os valores.
# NUNCA commite .env no Git!
# ==========================================

# ==========================================
# Supabase - Frontend (VITE_*)
# ==========================================

# Project ID do Supabase
VITE_SUPABASE_PROJECT_ID="xdtlhzysrpoinqtsglmr"

# Anon Key (pública, usada pelo frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=""

# URL do projeto Supabase
VITE_SUPABASE_URL="https://xdtlhzysrpoinqtsglmr.supabase.co"

# ==========================================
# Supabase - Backend (NUNCA expor no frontend)
# ==========================================

# URL do projeto (mesma do VITE_SUPABASE_URL)
SUPABASE_URL="https://xdtlhzysrpoinqtsglmr.supabase.co"

# 🔴 CRÍTICO: Service Role Key - NUNCA commitar!
# Configura como Codespace Secret: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=""

# 🔴 CRÍTICO: Senha do banco PostgreSQL direto
# Configura como Codespace Secret: SUPABASE_DB_PASSWORD
SUPABASE_DB_PASSWORD=""

# ==========================================
# API CNPJA (Consulta de CNPJs)
# ==========================================

# Configura como Codespace Secret: CNPJA_API_KEY
CNPJA_API_KEY=""

# ==========================================
# NFS-e (Nota Fiscal de Serviço)
# ==========================================

# Certificado A1 (.pfx) em base64 (uma única linha)
NFSE_CERT_PFX_B64=""

# Senha do certificado PFX
NFSE_CERT_PASSWORD=""

# ==========================================
# Cora Bank (Banco 403 - Integração Bancária)
# ==========================================
# Configure nos Edge Function Secrets do Supabase:
#   Dashboard → Edge Functions → Secrets
#   supabase secrets set CORA_CLIENT_ID=... CORA_CLIENT_SECRET=...
#
# Obtenha as credenciais em: https://developers.cora.com.br

# Client ID OAuth2 (gerado no portal Cora)
# CORA_CLIENT_ID=""

# Client Secret OAuth2 (gerado no portal Cora)
# CORA_CLIENT_SECRET=""

# URL base da API Cora (padrão: https://api.cora.com.br)
# CORA_API_URL="https://api.cora.com.br"

# Secret para validar assinatura HMAC dos webhooks
# CORA_WEBHOOK_SECRET=""

# ==========================================
# Stripe (Sistema de Billing)
# ==========================================

# Chave pública (frontend - pode ser exposta)
VITE_STRIPE_PUBLISHABLE_KEY=""

# Chave secreta (backend - NUNCA expor no frontend)
# Configure nos Edge Function Secrets do Supabase:
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ==========================================
# Tenant padrão (Ampla Contabilidade)
# ==========================================
TENANT_ID="a53a4957-fe97-4856-b3ca-70045157b421"
